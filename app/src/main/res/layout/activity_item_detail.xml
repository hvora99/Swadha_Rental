<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA"
    android:padding="20dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="55dp"
        app:cardElevation="8dp"
        app:strokeWidth="3dp"
        app:strokeColor="#FFFFFF">

        <TextView
            android:id="@+id/tvDetailItemCode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#800020"
            android:gravity="center"
            android:text="CH01"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-45dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="65dp"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Details"
                android:textColor="#BDBDBD"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etDetailItemName"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="8dp"
                android:textColor="#000000"
                android:background="@drawable/bg_minimal_line"
                android:hint="Item Name"
                android:paddingHorizontal="16dp"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <EditText
                    android:id="@+id/etDetailRent"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_minimal_line"
                    android:hint="Rent (₹)"
                    android:textColor="#000000"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/etDetailDeposit"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_minimal_line"
                    android:hint="Deposit (₹)"
                    android:textColor="#000000"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <Button
                    android:id="@+id/btnUpdateItem"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1.5"
                    android:text="Update"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:backgroundTint="#0A0A0A" />

                <Button
                    android:id="@+id/btnRemoveItem"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Remove"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:layout_marginStart="10dp"
                    android:backgroundTint="#D32F2F" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btnToggleLock"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="Lock Item"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF9800"
        android:textAllCaps="false"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Active Rental History"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#1A1C1E"
        android:layout_marginTop="28dp"
        android:layout_marginStart="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCurrentBooking"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/tvNoBooking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No Active Bookings"
        android:gravity="center"
        android:textSize="14sp"
        android:nestedScrollingEnabled="false"
        android:textColor="#999999"
        android:padding="40dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_minimal_line"
        android:visibility="visible"/>

</LinearLayout>